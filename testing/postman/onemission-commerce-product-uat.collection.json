    {
      "name": "Commerce Products",
      "item": [
        {
          "name": "Get Product Listing",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () { pm.response.to.have.status(200); });",
                  "const response = pm.response.json();",
                  "pm.test('Response contains data array', function () { pm.expect(Array.isArray(response.data)).to.eql(true); });",
                  "pm.test('Response contains pagination object', function () { pm.expect(response.pagination).to.be.an('object'); });",
                  "pm.test('Response contains filters object', function () { pm.expect(response.filters).to.be.an('object'); });",
                  "if (response.data && response.data.length > 0) {",
                  "  pm.environment.set('productSlug', response.data[0].slug);",
                  "  pm.environment.set('categorySlug', response.data[0].category);",
                  "}",
                  "const outOfStock = (response.data || []).find((item) => item.stockStatus === 'OUT_OF_STOCK');",
                  "if (outOfStock) { pm.environment.set('outOfStockSlug', outOfStock.slug); }"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/commerce/products?page={{page}}&limit={{limit}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "commerce", "products"],
              "query": [
                { "key": "page", "value": "{{page}}" },
                { "key": "limit", "value": "{{limit}}" }
              ]
            }
          }
        },
