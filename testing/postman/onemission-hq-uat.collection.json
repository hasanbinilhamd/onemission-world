    },
    {
      "name": "Negative Tests",
      "item": [
        {
          "name": "Expired Checkout",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/checkout/session/replace-with-expired-checkout-session-id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "checkout", "session", "replace-with-expired-checkout-session-id"]
            },
            "description": "Replace the path parameter with a real expired checkout session ID."
          }
        },
        {
          "name": "Duplicate PaymentAttempt",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"checkoutSessionId\": \"{{checkoutSessionId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payment-attempt",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payment-attempt"]
            },
            "description": "Run this request twice for the same checkoutSessionId. The second response must reuse the existing active payment attempt."
          }
        },
        {
          "name": "Invalid Checkout ID",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"checkoutSessionId\": \"invalid-checkout-id\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/payment-attempt",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payment-attempt"]
            }
          }
        },
        {
          "name": "Invalid PaymentAttempt ID",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/payment-attempt/invalid-payment-attempt-id/snap",
              "host": ["{{baseUrl}}"],
              "path": ["api", "payment-attempt", "invalid-payment-attempt-id", "snap"]
            }
          }
        }
      ]
    }
  ]
}
