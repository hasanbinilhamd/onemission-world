generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String        @id
  email               String        @unique
  password            String
  passwordHash        String?
  name                String
  role                String
  avatar              String        @default("")
  status              String        @default("Active")
  lastLoginAt         DateTime?
  passwordChangedAt   DateTime?
  failedLoginAttempts Int           @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  sessions            UserSession[]
  auditLogs           AuditLog[]
}

model Role {
  id          String           @id
  name        String           @unique
  description String           @default("")
  status      String           @default("Active")
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
}

model RolePermission {
  id         String   @id
  roleId     String
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  moduleKey  String
  actionKey  String
  isAllowed  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([roleId, moduleKey, actionKey])
  @@index([moduleKey])
  @@index([actionKey])
}

model SystemSetting {
  id          String   @id
  settingKey  String   @unique
  section     String
  label       String
  value       String
  valueType   String   @default("string")
  description String   @default("")
  updatedBy   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([section])
}

model NotificationSetting {
  id          String   @id
  category    String
  settingKey  String   @unique
  label       String
  isEnabled   Boolean  @default(true)
  updatedBy   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

model UserSession {
  id             String   @id
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash      String   @unique
  device         String   @default("")
  browser        String   @default("")
  ipAddress      String   @default("")
  userAgent      String   @default("")
  lastActivityAt DateTime @default(now())
  expiresAt      DateTime
  revokedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id          String   @id
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  userName    String   @default("")
  action      String
  module      String
  description String
  ipAddress   String   @default("")
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([module])
  @@index([action])
  @@index([createdAt])
}

model Product {
  id             String          @id
  name           String
  sku            String
  category       String
  brand          String
  status         String
  costPrice      Float
  sellingPrice   Float
  description    String
  tags           String[]
  colors         String[]
  sizes          String[]
  notes          String          @default("")
  imageUrl       String          @default("")
  inventory        Inventory[]
  stockMovements   StockMovement[]
  boms             BOM[]
  productionOrders ProductionOrder[]
}

model Inventory {
  id             String          @id
  productId      String
  product        Product         @relation(fields: [productId], references: [id])
  color          String
  size           String
  quantity       Int
  averageCost    Float           @default(0)
  threshold      Int
  incoming       Int
  status         String          @default("Active")
  stockMovements StockMovement[]

  @@unique([productId, color, size])
}

model StockMovement {
  id               String       @id
  itemType         String       @default("PRODUCT")
  inventoryId      String?
  inventory        Inventory?   @relation(fields: [inventoryId], references: [id])
  productId        String?
  product          Product?     @relation(fields: [productId], references: [id])
  rawMaterialId    String?
  rawMaterial      RawMaterial? @relation(fields: [rawMaterialId], references: [id])
  color            String       @default("")
  size             String       @default("")
  movementDate     String
  movementType     String
  quantity         Float
  quantityChanged  Float        @default(0)
  previousQuantity Float
  newQuantity      Float
  notes            String       @default("")
  referenceType    String       @default("")
  referenceId      String       @default("")
  referenceNumber  String       @default("")
  performedBy      String       @default("")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([inventoryId])
  @@index([productId])
  @@index([rawMaterialId])
  @@index([movementDate])
  @@index([movementType])
  @@index([itemType])
  @@index([referenceType])
  @@index([referenceId])
}

model Plan {
  id           String   @id
  level        String
  title        String
  objective    String
  progress     Int
  status       String
  owner        String
  dueDate      String
  notes        String   @default("")
  keyResults   String[]
  actionItems  String[]
}

model Content {
  id        String @id
  title     String
  platform  String
  format    String
  caption   String
  objective String
  cta       String
  owner     String
  deadline  String
  status    String
}

model ContentPlanner {
  id          String   @id
  title       String
  category    String   @default("Other")
  calendarDate String
  pdfUrl      String
  pdfFilename String
  createdBy   String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([calendarDate])
  @@index([category])
  @@index([createdAt])
}

model Creator {
  id          String @id
  name        String
  username    String
  platform    String
  followers   Int
  engagement  Float
  niche       String
  audienceFit Int
  valuesScore Int
  contact     String
  fee         Float
  status      String
  notes       String @default("")
}

model School {
  id            String @id
  name          String
  city          String
  province      String
  contactPerson String
  phone         String
  email         String
  segment       String
  value         Float
  status        String
  notes         String @default("")
}

model Timeline {
  id          String @id
  year        Int
  name        String
  description String
  startDate   String
  endDate     String
  owner       String
  status      String
  priority    String
  budget      Float
}

model Finance {
  id                String @id
  month             String
  year              Int
  revenue           Float
  expenses          Float
  profit            Float
  cashflow          Float
  categoryBreakdown Json
}

model Event {
  id           String   @id
  name         String
  venue        String
  date         String
  budget       Float
  sponsors     String[]
  participants Int
  status       String
  checklist    Json
}

model Notification {
  id         String  @id
  type       String
  module     String  @default("")
  title      String
  message    String
  actionUrl  String  @default("")
  actionLabel String @default("")
  referenceId String @default("")
  createdAt  String
  read       Boolean
  severity   String
}

model Supplier {
  id            String        @id
  supplierCode  String        @unique
  supplierName  String
  contactPerson String        @default("")
  phone         String        @default("")
  email         String        @default("")
  address       String        @default("")
  city          String        @default("")
  province      String        @default("")
  country       String        @default("Indonesia")
  leadTimeDays  Int           @default(0)
  notes         String        @default("")
  status        String        @default("Active")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  rawMaterials  RawMaterial[]
}

model RawMaterial {
  id             String          @id
  name           String
  color          String
  weight         Float
  photo          String?
  category       String          @default("")
  unit           String          @default("")
  currentStock   Float           @default(0)
  minimumStock   Float           @default(0)
  unitCost       Float           @default(0)
  supplierName   String          @default("")
  supplierId     String?
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  notes          String          @default("")
  status         String          @default("Active")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]
  bomItems       BOMItem[]

  @@index([supplierId])
}

model ProductionOrder {
  id                    String            @id
  productionOrderNumber String            @unique
  productId             String
  product               Product           @relation(fields: [productId], references: [id])
  bomId                 String
  bom                   BOM               @relation(fields: [bomId], references: [id])
  plannedQuantity       Float
  plannedDate           String
  status                String            @default("Draft")
  notes                 String            @default("")
  actualQuantity        Float?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  productionResult      ProductionResult?

  @@index([productId])
  @@index([bomId])
  @@index([status])
}

model ProductionResult {
  id                  String          @id
  resultNumber        String          @unique
  productionOrderId   String          @unique
  productionOrder     ProductionOrder @relation(fields: [productionOrderId], references: [id])
  totalMaterialCost   Float           @default(0)
  laborCost           Float           @default(0)
  factoryOverheadCost Float           @default(0)
  otherCost           Float           @default(0)
  totalProductionCost Float           @default(0)
  unitProductionCost  Float           @default(0)
  createdAt           DateTime        @default(now())

  @@index([productionOrderId])
}

model BOM {
  id          String    @id
  bomCode     String    @unique
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  version     String    @default("1.0")
  description String    @default("")
  status      String    @default("Active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  items            BOMItem[]
  productionOrders ProductionOrder[]

  @@index([productId])
  @@index([status])
}

model BOMItem {
  id               String      @id
  bomId            String
  bom              BOM         @relation(fields: [bomId], references: [id], onDelete: Cascade)
  rawMaterialId    String
  rawMaterial      RawMaterial @relation(fields: [rawMaterialId], references: [id])
  quantityRequired Float
  notes            String      @default("")

  @@index([bomId])
  @@index([rawMaterialId])
}

model ChartOfAccount {
  id                      String             @id
  accountCode             String             @unique
  accountName             String
  accountType             String
  normalBalance           String
  description             String             @default("")
  isActive                Boolean            @default(true)
  allowTransaction        Boolean            @default(true)
  parentId                String?
  parent                  ChartOfAccount?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children                ChartOfAccount[]   @relation("AccountHierarchy")
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  cashTransactions        CashTransaction[]
  journalLines            JournalEntryLine[]
  linkedFinancialAccounts FinancialAccount[] @relation("FALinkedCoa")
}

model FinancialAccount {
  id               String            @id
  name             String            @unique
  type             String
  accountNumber    String            @default("")
  bankName         String            @default("")
  openingBalance   Float             @default(0)
  description      String            @default("")
  isActive         Boolean           @default(true)
  linkedCoaId      String?
  linkedCoa        ChartOfAccount?   @relation("FALinkedCoa", fields: [linkedCoaId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  cashTransactions CashTransaction[]
}

model ExpenseCategory {
  id               String            @id
  name             String            @unique
  description      String            @default("")
  status           String            @default("Active")
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  cashTransactions CashTransaction[]
}

model CashTransaction {
  id                  String            @id
  transactionDate     String
  transactionType     String
  financialAccountId  String
  financialAccount    FinancialAccount  @relation(fields: [financialAccountId], references: [id])
  chartOfAccountId    String
  chartOfAccount      ChartOfAccount    @relation(fields: [chartOfAccountId], references: [id])
  expenseCategoryId   String?
  expenseCategory     ExpenseCategory?  @relation(fields: [expenseCategoryId], references: [id])
  expenseCategoryName String            @default("")
  amount              Float
  referenceNumber     String            @default("")
  description         String            @default("")
  vendor              String            @default("")
  paymentMethod       String            @default("")
  attachment          String            @default("")
  notes               String            @default("")
  createdBy           String            @default("")
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([expenseCategoryId])
  @@index([transactionType])
  @@index([transactionDate])
}

model JournalEntry {
  id              String             @id
  journalNumber   String             @unique
  journalDate     String
  description     String
  referenceNumber String             @default("")
  journalSource   String
  sourceId        String             @default("")
  journalType     String             @default("Manual")
  status          String             @default("Draft")
  totalDebit      Float              @default(0)
  totalCredit     Float              @default(0)
  createdBy       String             @default("")
  updatedBy       String             @default("")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  lines           JournalEntryLine[]
}

model JournalEntryLine {
  id               String         @id
  journalEntryId   String
  journalEntry     JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  chartOfAccountId String
  chartOfAccount   ChartOfAccount @relation(fields: [chartOfAccountId], references: [id])
  description      String         @default("")
  debitAmount      Float          @default(0)
  creditAmount     Float          @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model SalesChannel {
  id               String            @id
  channelCode      String            @unique
  channelName      String
  channelType      String
  description      String            @default("")
  status           String            @default("Active")
  isDefault        Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  customers        Customer[]
}

model Customer {
  id                      String            @id
  customerCode            String            @unique
  customerName            String
  email                   String?           @unique
  phone                   String?           @unique
  passwordHash            String?
  passwordResetToken      String?
  passwordResetTokenExpiresAt DateTime?
  googleId                String?           @unique
  emailVerified           Boolean           @default(false)
  emailVerifiedAt         DateTime?
  avatarUrl               String?
  lastLoginAt             DateTime?
  authProvider            String            @default("LOCAL")
  customerType            String            @default("Individual")
  isGuest                 Boolean           @default(false)
  preferredSalesChannelId String?
  preferredSalesChannel   SalesChannel?     @relation(fields: [preferredSalesChannelId], references: [id])
  provinceId              String            @default("")
  province                String            @default("")
  cityId                  String            @default("")
  city                    String            @default("")
  districtId              String            @default("")
  district                String            @default("")
  postalCode              String            @default("")
  streetAddress           String            @default("")
  country                 String            @default("Indonesia")
  notes                   String            @default("")
  status                  String            @default("Active")
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  sessions                CustomerSession[]
  addresses               CustomerAddress[]
  returnRequests          ReturnRequest[]

  @@index([passwordResetToken])
  @@index([passwordResetTokenExpiresAt])
}

model CustomerAddress {
  id            String   @id
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  recipientName String
  phoneNumber   String
  provinceId    String
  province      String
  cityId        String
  city          String
  districtId    String
  district      String
  postalCode    String
  streetAddress String
  notes         String   @default("")
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId])
  @@index([customerId, isDefault])
}

model CustomerSession {
  id               String   @id
  customerId       String
  customer         Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  refreshTokenHash String
  device           String   @default("")
  browser          String   @default("")
  ipAddress        String   @default("")
  userAgent        String   @default("")
  expiresAt        DateTime
  lastUsedAt       DateTime @default(now())
  createdAt        DateTime @default(now())
  revokedAt        DateTime?

  @@index([customerId])
  @@index([expiresAt])
  @@index([revokedAt])
}

enum VerificationType {
  REGISTER
  RESET_PASSWORD
  CHANGE_EMAIL
  LOGIN_OTP
}

model VerificationToken {
  id          String           @id @default(cuid())
  type        VerificationType
  identifier  String
  otpHash     String
  payload     Json?
  expiresAt   DateTime
  attempts    Int              @default(0)
  resendCount Int              @default(0)
  verifiedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([type, identifier])
  @@index([identifier])
  @@index([type])
  @@index([expiresAt])
}

model CheckoutSession {
  id                  String                @id
  checkoutNumber      String                @unique
  status              String                @default("DRAFT")
  customerId          String
  customerCode        String                @default("")
  customerName        String                @default("")
  customerEmail       String                @default("")
  customerPhone       String                @default("")
  salesChannelId      String
  salesChannelCode    String                @default("")
  salesChannelName    String                @default("")
  currency            String                @default("IDR")
  subtotal            Float                 @default(0)
  shippingCost        Float                 @default(0)
  discount            Float                 @default(0)
  tax                 Float                 @default(0)
  grandTotal          Float                 @default(0)
  recipientName       String                @default("")
  phone               String                @default("")
  originDistrict      String
  destinationDistrict String
  courier             String
  courierService      String
  shippingDescription String                @default("")
  estimatedDelivery   String                @default("")
  provinceId          String
  provinceName        String                @default("")
  cityId              String
  cityName            String                @default("")
  districtId          String
  districtName        String                @default("")
  postalCode          String                @default("")
  streetAddress       String                @default("")
  processingKey       String?
  processingStartedAt DateTime?
  expiresAt           DateTime
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  items               CheckoutSessionItem[]
  paymentAttempts     PaymentAttempt[]
  orders              Order[]

  @@index([customerId])
  @@index([salesChannelId])
  @@index([status])
  @@index([expiresAt])
  @@index([processingKey])
}

model CheckoutSessionItem {
  id           String          @id
  checkoutId   String
  checkout     CheckoutSession @relation(fields: [checkoutId], references: [id], onDelete: Cascade)
  productId    String
  variantId    String
  productName  String
  variantName  String
  productImage String          @default("")
  weight       Float           @default(0)
  sku          String
  qty          Int
  price        Float
  currency     String          @default("IDR")
  subtotal     Float
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([checkoutId])
  @@index([productId])
  @@index([variantId])
}

model PaymentAttempt {
  id                    String          @id
  attemptNumber         String          @unique
  checkoutSessionId     String
  checkoutSession       CheckoutSession @relation(fields: [checkoutSessionId], references: [id], onDelete: Cascade)
  orderId               String?
  order                 Order?          @relation("OrderPaymentAttempts", fields: [orderId], references: [id], onDelete: SetNull)
  provider              String
  providerReference     String          @default("")
  providerTransactionId String          @default("")
  snapToken             String          @default("")
  snapRedirectUrl       String          @default("")
  status                String          @default("CREATED")
  grossAmount           Float
  currency              String          @default("IDR")
  paymentType           String          @default("")
  issuer                String          @default("")
  acquirer              String          @default("")
  fraudStatus           String          @default("")
  transactionTime       DateTime?
  settlementTime        DateTime?
  providerPayload       Json?
  expiresAt             DateTime
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  currentForOrder       Order?          @relation("OrderCurrentPaymentAttempt")

  @@index([checkoutSessionId])
  @@index([orderId])
  @@index([status])
}

model Order {
  id                  String      @id
  orderNumber         String      @unique
  publicOrderNumber   String      @unique
  checkoutSessionId   String      @unique
  checkoutSession     CheckoutSession @relation(fields: [checkoutSessionId], references: [id], onDelete: Cascade)
  paymentAttemptId    String?     @unique
  paymentAttempt      PaymentAttempt? @relation("OrderCurrentPaymentAttempt", fields: [paymentAttemptId], references: [id], onDelete: SetNull)
  paymentAttempts     PaymentAttempt[] @relation("OrderPaymentAttempts")
  paymentReference    String      @default("")
  customerId          String
  customerCode        String      @default("")
  customerName        String      @default("")
  customerEmail       String      @default("")
  customerPhone       String      @default("")
  salesChannelId      String
  salesChannelCode    String      @default("")
  salesChannelName    String      @default("")
  recipientName       String      @default("")
  recipientPhone      String      @default("")
  originDistrict      String      @default("")
  destinationDistrict String      @default("")
  courier             String      @default("")
  courierService      String      @default("")
  shippingDescription String      @default("")
  estimatedDelivery   String      @default("")
  provinceId          String      @default("")
  provinceName        String      @default("")
  cityId              String      @default("")
  cityName            String      @default("")
  districtId          String      @default("")
  districtName        String      @default("")
  postalCode          String      @default("")
  streetAddress       String      @default("")
  status              String      @default("READY_FOR_FULFILLMENT")
  fulfillmentStatus   String      @default("PENDING")
  shipmentCourier     String      @default("")
  shipmentService     String      @default("")
  trackingNumber      String      @default("")
  shippingDate        DateTime?
  currency            String      @default("IDR")
  subtotal            Float       @default(0)
  discount            Float       @default(0)
  shippingCost        Float       @default(0)
  tax                 Float       @default(0)
  grandTotal          Float       @default(0)
  orderConfirmationEmailSentAt DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  items               OrderItem[]
  timelines           OrderTimeline[]
  returnRequest       ReturnRequest?

  @@index([customerId])
  @@index([salesChannelId])
  @@index([status])
  @@index([fulfillmentStatus])
}

model OrderItem {
  id           String @id
  orderId      String
  order        Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId    String
  variantId    String
  sku          String
  productName  String
  variantName  String
  productImage String  @default("")
  price        Float
  weight       Float   @default(0)
  quantity     Int
  subtotal     Float
  currency     String  @default("IDR")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model OrderTimeline {
  id        String   @id
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventName String
  updatedBy String   @default("")
  notes     String   @default("")
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([createdAt])
}

model ReturnRequest {
  id           String   @id
  orderId       String   @unique
  order         Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  reason        String
  description   String   @default("")
  status        String   @default("REQUESTED")
  rejectReason  String   @default("")
  refundStatus  String   @default("NONE")
  attachments   String[]
  requestedAt   DateTime @default(now())
  approvedAt    DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([refundStatus])
  @@index([requestedAt])
}
