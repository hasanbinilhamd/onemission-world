generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id
  email    String @unique
  password String
  name     String
  role     String
  avatar   String
}

model Product {
  id             String          @id
  name           String
  sku            String
  category       String
  brand          String
  status         String
  costPrice      Float
  sellingPrice   Float
  description    String
  tags           String[]
  colors         String[]
  sizes          String[]
  notes          String          @default("")
  imageUrl       String          @default("")
  inventory        Inventory[]
  stockMovements   StockMovement[]
  boms             BOM[]
  productionOrders ProductionOrder[]
}

model Inventory {
  id             String          @id
  productId      String
  product        Product         @relation(fields: [productId], references: [id])
  color          String
  size           String
  quantity       Int
  threshold      Int
  incoming       Int
  stockMovements StockMovement[]
}

model StockMovement {
  id               String       @id
  itemType         String       @default("PRODUCT")
  inventoryId      String?
  inventory        Inventory?   @relation(fields: [inventoryId], references: [id])
  productId        String?
  product          Product?     @relation(fields: [productId], references: [id])
  rawMaterialId    String?
  rawMaterial      RawMaterial? @relation(fields: [rawMaterialId], references: [id])
  movementDate     String
  movementType     String
  quantity         Float
  previousQuantity Float
  newQuantity      Float
  notes            String       @default("")
  referenceNumber  String       @default("")
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([inventoryId])
  @@index([productId])
  @@index([rawMaterialId])
  @@index([movementDate])
  @@index([movementType])
  @@index([itemType])
}

model Plan {
  id           String   @id
  level        String
  title        String
  objective    String
  progress     Int
  status       String
  owner        String
  dueDate      String
  notes        String   @default("")
  keyResults   String[]
  actionItems  String[]
}

model Content {
  id        String @id
  title     String
  platform  String
  format    String
  caption   String
  objective String
  cta       String
  owner     String
  deadline  String
  status    String
}

model Creator {
  id          String @id
  name        String
  username    String
  platform    String
  followers   Int
  engagement  Float
  niche       String
  audienceFit Int
  valuesScore Int
  contact     String
  fee         Float
  status      String
  notes       String @default("")
}

model School {
  id            String @id
  name          String
  city          String
  province      String
  contactPerson String
  phone         String
  email         String
  segment       String
  value         Float
  status        String
  notes         String @default("")
}

model Timeline {
  id          String @id
  year        Int
  name        String
  description String
  startDate   String
  endDate     String
  owner       String
  status      String
  priority    String
  budget      Float
}

model Finance {
  id                String @id
  month             String
  year              Int
  revenue           Float
  expenses          Float
  profit            Float
  cashflow          Float
  categoryBreakdown Json
}

model Event {
  id           String   @id
  name         String
  venue        String
  date         String
  budget       Float
  sponsors     String[]
  participants Int
  status       String
  checklist    Json
}

model Notification {
  id        String  @id
  type      String
  title     String
  message   String
  createdAt String
  read      Boolean
  severity  String
}

model Supplier {
  id            String        @id
  supplierCode  String        @unique
  supplierName  String
  contactPerson String        @default("")
  phone         String        @default("")
  email         String        @default("")
  address       String        @default("")
  city          String        @default("")
  province      String        @default("")
  country       String        @default("Indonesia")
  leadTimeDays  Int           @default(0)
  notes         String        @default("")
  status        String        @default("Active")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  rawMaterials  RawMaterial[]
}

model RawMaterial {
  id             String          @id
  name           String
  color          String
  weight         Float
  photo          String?
  category       String          @default("")
  unit           String          @default("")
  currentStock   Float           @default(0)
  minimumStock   Float           @default(0)
  unitCost       Float           @default(0)
  supplierName   String          @default("")
  supplierId     String?
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  notes          String          @default("")
  status         String          @default("Active")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  stockMovements StockMovement[]
  bomItems       BOMItem[]

  @@index([supplierId])
}

model ProductionOrder {
  id                    String   @id
  productionOrderNumber String   @unique
  productId             String
  product               Product  @relation(fields: [productId], references: [id])
  bomId                 String
  bom                   BOM      @relation(fields: [bomId], references: [id])
  plannedQuantity       Float
  plannedDate           String
  status                String    @default("Draft")
  notes                 String    @default("")
  actualQuantity        Float?
  startedAt             DateTime?
  completedAt           DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([productId])
  @@index([bomId])
  @@index([status])
}

model BOM {
  id          String    @id
  bomCode     String    @unique
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  version     String    @default("1.0")
  description String    @default("")
  status      String    @default("Active")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  items            BOMItem[]
  productionOrders ProductionOrder[]

  @@index([productId])
  @@index([status])
}

model BOMItem {
  id               String      @id
  bomId            String
  bom              BOM         @relation(fields: [bomId], references: [id], onDelete: Cascade)
  rawMaterialId    String
  rawMaterial      RawMaterial @relation(fields: [rawMaterialId], references: [id])
  quantityRequired Float
  notes            String      @default("")

  @@index([bomId])
  @@index([rawMaterialId])
}

model ChartOfAccount {
  id                      String             @id
  accountCode             String             @unique
  accountName             String
  accountType             String
  normalBalance           String
  description             String             @default("")
  isActive                Boolean            @default(true)
  allowTransaction        Boolean            @default(true)
  parentId                String?
  parent                  ChartOfAccount?    @relation("AccountHierarchy", fields: [parentId], references: [id])
  children                ChartOfAccount[]   @relation("AccountHierarchy")
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  cashTransactions        CashTransaction[]
  journalLines            JournalEntryLine[]
  linkedFinancialAccounts FinancialAccount[] @relation("FALinkedCoa")
}

model FinancialAccount {
  id               String            @id
  name             String            @unique
  type             String
  accountNumber    String            @default("")
  bankName         String            @default("")
  openingBalance   Float             @default(0)
  description      String            @default("")
  isActive         Boolean           @default(true)
  linkedCoaId      String?
  linkedCoa        ChartOfAccount?   @relation("FALinkedCoa", fields: [linkedCoaId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  cashTransactions CashTransaction[]
}

model CashTransaction {
  id                 String           @id
  transactionDate    String
  transactionType    String
  financialAccountId String
  financialAccount   FinancialAccount @relation(fields: [financialAccountId], references: [id])
  chartOfAccountId   String
  chartOfAccount     ChartOfAccount   @relation(fields: [chartOfAccountId], references: [id])
  amount             Float
  referenceNumber    String           @default("")
  description        String           @default("")
  attachment         String           @default("")
  createdBy          String           @default("")
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model JournalEntry {
  id              String             @id
  journalNumber   String             @unique
  journalDate     String
  description     String
  referenceNumber String             @default("")
  journalSource   String
  sourceId        String             @default("")
  journalType     String             @default("Manual")
  status          String             @default("Draft")
  totalDebit      Float              @default(0)
  totalCredit     Float              @default(0)
  createdBy       String             @default("")
  updatedBy       String             @default("")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  lines           JournalEntryLine[]
}

model JournalEntryLine {
  id               String         @id
  journalEntryId   String
  journalEntry     JournalEntry   @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  chartOfAccountId String
  chartOfAccount   ChartOfAccount @relation(fields: [chartOfAccountId], references: [id])
  description      String         @default("")
  debitAmount      Float          @default(0)
  creditAmount     Float          @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}
