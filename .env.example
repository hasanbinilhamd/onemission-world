# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/onemission_hq?schema=public"

# CORS (optional)
CORS_ORIGINS="*"

# Shipping gateway configuration
SHIPPING_PROVIDER="mock"
SHIPPING_SUPPORTED_COURIERS="jne,jnt,sicepat,pos,ninja,anteraja"
RAJAONGKIR_API_KEY=""
RAJAONGKIR_BASE_URL="https://rajaongkir.komerce.id/api/v1/"
RAJAONGKIR_TIMEOUT="15000"

# Payment gateway configuration
MIDTRANS_SERVER_KEY=""
MIDTRANS_CLIENT_KEY=""
MIDTRANS_IS_PRODUCTION="false"
MIDTRANS_TIMEOUT="15000"

# Application URLs
HQ_URL="http://localhost:3000"
COMMERCE_URL="http://localhost:5173"

# Customer authentication configuration
JWT_SECRET="change-this-secret"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="30d"
PASSWORD_RESET_EXPIRES="60m"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email delivery configuration
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM_NAME="ONEMISSION"
SMTP_FROM_EMAIL=""
