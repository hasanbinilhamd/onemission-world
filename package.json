{
    "name": "nextjs-mongo-template",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "prisma:generate": "prisma generate",
        "dev": "npm run prisma:generate && cross-env NODE_OPTIONS=--max-old-space-size=512 next dev --hostname 0.0.0.0 --port 3000",
        "dev:no-reload": "npm run prisma:generate && cross-env NODE_OPTIONS=--max-old-space-size=512 next dev --hostname 0.0.0.0 --port 3000",
        "dev:webpack": "npm run prisma:generate && cross-env NODE_OPTIONS=--max-old-space-size=512 next dev --hostname 0.0.0.0 --port 3000",
        "build": "prisma generate && next build",
        "start": "next start",
        "db:migrate": "prisma migrate dev",
        "db:seed": "prisma db seed",
        "seed:uat": "tsx testing/seeds/uat-seed.ts",
        "seed:products": "tsx prisma/seeds/product-seed.ts",
        "test:checkout": "tsx --tsconfig jsconfig.json --test tests/checkout-session.test.js",
        "test:payment-attempt": "tsx --tsconfig jsconfig.json --test tests/payment-attempt.test.js",
        "test:order": "tsx --tsconfig jsconfig.json --test tests/order-service.test.js",
        "test:uat": "npm run test:checkout && npm run test:payment-attempt && npm run test:order",
        "postinstall": "prisma generate"
    },
    "prisma": {
        "seed": "tsx prisma/seed.ts"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
